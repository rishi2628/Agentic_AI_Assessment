# ─────────────────────────────────────────────────────────────────────
# Policy & Incident Copilot — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is already in .gitignore — never commit secrets.
# ─────────────────────────────────────────────────────────────────────

# ── Primary LLM: Ollama (free, runs 100 % locally) ──────────────────
# Install Ollama from https://ollama.ai then run:
#   ollama pull llama3.2:3b          # tiny, fast on CPU
#   ollama pull mistral:7b-instruct  # better quality, needs ~8 GB RAM
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b

# ── Alternative LLM: Groq free-tier (cloud, no GPU needed) ──────────
# Get a free key at https://console.groq.com
# Then swap LLM_PROVIDER to "groq" below.
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama3-8b-8192

# ── LLM Provider switch ─────────────────────────────────────────────
# "ollama" (default) | "groq"
LLM_PROVIDER=ollama

# ── Embeddings ───────────────────────────────────────────────────────
# sentence-transformers model downloaded automatically from HuggingFace
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Application paths ────────────────────────────────────────────────
VECTORSTORE_PATH=./vectorstore
POLICIES_PATH=./data/policies

# ── Guardrails / safety ──────────────────────────────────────────────
MAX_STEPS=10
MAX_REVISIONS=2

# ── LangSmith tracing (leave false unless you have a LangSmith account) ──────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=none

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
